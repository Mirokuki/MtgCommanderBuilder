<Window x:Class="MtgCommanderBuilder.Views.GoalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MtgCommanderBuilder.Views"
        Title="Deck Goals" Height="680" Width="920"
        WindowStartupLocation="CenterOwner"
        Background="#0d0e12" Foreground="White"
        BorderBrush="#2c2e3c" BorderThickness="1"
        WindowStyle="None" ResizeMode="NoResize">
    
    <Border BorderBrush="#20222a" BorderThickness="1" CornerRadius="8" Background="#0d0e12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Goals Content -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="#111218" Padding="20,16" BorderBrush="#20222a" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE102;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Adjust Target Deck Goals" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Grid.Column="1" Content="Apply &amp; Close" Click="Close_Click" Padding="14,8" Background="#5c2bb0" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Goals View Content -->
            <views:GoalsView Grid.Row="1" Margin="8"/>
        </Grid>
    </Border>
</Window>
