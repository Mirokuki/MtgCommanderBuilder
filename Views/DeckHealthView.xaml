<UserControl x:Class="MtgCommanderBuilder.Views.DeckHealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MtgCommanderBuilder.Views"
             xmlns:converters="clr-namespace:MtgCommanderBuilder.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <converters:PercentageToStrokeDashArrayConverter x:Key="PercentToDashConverter"/>
    </UserControl.Resources>

    <Border Background="#0d0e12" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.2*"/> <!-- Top dashboard split -->
                <RowDefinition Height="1*"/>   <!-- Bottom analytics charts split -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= TOP LEFT: HEALTH SCORE GAUGE ================= -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="DECK HEALTH SCORE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" HorizontalAlignment="Center"/>

                    <Grid Grid.Row="1" Width="140" Height="140" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Stroke="#1c1d24" StrokeThickness="10" Width="130" Height="130"/>
                        <!-- 91% Excellent Health Ring -->
                        <Ellipse Stroke="#2ecc71" StrokeThickness="10" 
                                 StrokeDashArray="37.16, 3.68" 
                                 Width="130" Height="130" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="91%" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Excellent" FontSize="10" FontWeight="SemiBold" Foreground="#2ecc71" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ================= TOP MIDDLE: HEALTH CATEGORY CHECKLIST ================= -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="HEALTH BY CATEGORY" FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <!-- Lands -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Lands" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="27 / 27" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <!-- Ramp -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Ramp" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="18 / 16-30" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <!-- Draw -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Draw" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="24 / 20-28" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <!-- Removal -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#e67e22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Removal" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="22 / 24-34" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <!-- Wipes -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Board Wipes" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="12 / 10-18" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= TOP RIGHT: STRATEGY PROFILE (RADAR CHART) ================= -->
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="STRATEGY PROFILE" FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                    <Grid Grid.Row="1" Width="130" Height="130" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Radar Grid backing layout -->
                        <Polygon Points="65,10 115,45 95,110 35,110 15,45" Stroke="#20222a" StrokeThickness="1" Fill="Transparent"/>
                        <Polygon Points="65,30 95,50 85,90 45,90 35,50" Stroke="#20222a" StrokeThickness="1" Fill="Transparent"/>

                        <!-- Actual Strategy Polygon (Midrange/Control focus) -->
                        <Polygon Points="65,15 105,48 85,92 48,105 28,48" Stroke="#5c2bb0" StrokeThickness="2" Fill="#405c2bb0"/>

                        <!-- Labels -->
                        <TextBlock Text="CTRL" FontSize="8" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold" Margin="0,-2,0,0" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                        <TextBlock Text="MID" FontSize="8" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold" Margin="0,40,-5,0" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <TextBlock Text="AGG" FontSize="8" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold" Margin="0,0,-2,16" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <TextBlock Text="STX" FontSize="8" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold" Margin="-2,0,0,16" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <TextBlock Text="GYD" FontSize="8" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold" Margin="-5,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ================= BOTTOM LEFT: CURVE CONSISTENCY LINE GRAPH ================= -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CURVE CONSISTENCY" FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                    <!-- Smooth line chart -->
                    <Grid Grid.Row="1">
                        <!-- Y-Axis markings -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Stretch" Margin="0,0,12,0" Height="100">
                            <TextBlock Text="1.0" FontSize="8" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="0.5" FontSize="8" Foreground="{StaticResource TextMutedBrush}" Margin="0,34,0,0"/>
                            <TextBlock Text="0.0" FontSize="8" Foreground="{StaticResource TextMutedBrush}" Margin="0,34,0,0"/>
                        </StackPanel>

                        <!-- Vector line graph path -->
                        <Grid Grid.Column="1" Height="100" VerticalAlignment="Center">
                            <!-- Background horizontal grid lines -->
                            <Separator VerticalAlignment="Top" Background="#1a1b22" Margin="0,2,0,0"/>
                            <Separator VerticalAlignment="Center" Background="#1a1b22"/>
                            <Separator VerticalAlignment="Bottom" Background="#1a1b22" Margin="0,0,0,2"/>

                            <!-- Line Path -->
                            <Polyline Points="10,80 50,60 90,25 130,40 170,72 210,88 250,92 290,95" Stroke="#3498db" StrokeThickness="2.5"/>
                            <Polyline Points="10,80 50,60 90,25 130,40 170,72 210,88 250,92 290,95 290,100 10,100" Fill="#153498db"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ================= BOTTOM RIGHT: KEY STRENGTHS ================= -->
            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="KEY STRENGTHS" FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="High Card Advantage" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Strong Control Elements" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Good Synergy &amp; ETB Value" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#2ecc71" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Flexible WUBRG Mana Sources" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
