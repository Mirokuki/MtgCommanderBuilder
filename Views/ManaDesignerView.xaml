<UserControl x:Class="MtgCommanderBuilder.Views.ManaDesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MtgCommanderBuilder.Views"
             xmlns:converters="clr-namespace:MtgCommanderBuilder.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <converters:PercentageToStrokeDashArrayConverter x:Key="PercentToDashConverter"/>

        <Style TargetType="Slider">
            <Setter Property="Background" Value="#1c1d24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#0d0e12" Padding="24">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/> <!-- Left: Curve & Lands Distribution -->
                <ColumnDefinition Width="1*"/>   <!-- Right: Consistency & Source circles -->
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: CURVE & LANDS -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Mana Curve -->
                    <RowDefinition Height="*"/>    <!-- Lands Sliders -->
                </Grid.RowDefinitions>

                <!-- Mana Value Curve Chart -->
                <Border Grid.Row="0" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="MANA VALUE CURVE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}"/>
                        <TextBlock Grid.Row="1" Text="Distribution of spells by casting cost" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,12"/>

                        <UniformGrid Grid.Row="2" Columns="8" VerticalAlignment="Bottom" Height="100">
                            <local:CurveBar ValueCount="0" MaxCount="{Binding MaxCmcCount}" Title="0" VerticalAlignment="Bottom"/>
                            <local:CurveBar ValueCount="1" MaxCount="{Binding MaxCmcCount}" Title="1" VerticalAlignment="Bottom"/>
                            <local:CurveBar ValueCount="2" MaxCount="{Binding MaxCmcCount}" Title="2" VerticalAlignment="Bottom"/>
                            <local:CurveBar ValueCount="3" MaxCount="{Binding MaxCmcCount}" Title="3" VerticalAlignment="Bottom"/>
                            <local:CurveBar ValueCount="4" MaxCount="{Binding MaxCmcCount}" Title="4" VerticalAlignment="Bottom"/>
                            <local:CurveBar ValueCount="5" MaxCount="{Binding MaxCmcCount}" Title="5" VerticalAlignment="Bottom"/>
                            <local:CurveBar ValueCount="6" MaxCount="{Binding MaxCmcCount}" Title="6" VerticalAlignment="Bottom"/>
                            <local:CurveBar ValueCount="7" MaxCount="{Binding MaxCmcCount}" Title="7+" VerticalAlignment="Bottom"/>
                        </UniformGrid>

                        <UniformGrid Grid.Row="3" Columns="8" Margin="0,4,0,0">
                            <TextBlock Text="0" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="1" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="2" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="3" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="4" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="5" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="6" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="7+" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- Lands Distribution Editor -->
                <Border Grid.Row="1" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="LANDS DISTRIBUTION" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Set ratios of basic, dual, fetch, and utility lands" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                            <StackPanel>
                                <!-- Basics -->
                                <StackPanel Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Basic Lands" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding BasicsCount}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                    <Slider Value="{Binding BasicsCount}" Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Duals -->
                                <StackPanel Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Dual / Multicolor Lands" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DualsCount}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                    <Slider Value="{Binding DualsCount}" Minimum="0" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Fetches -->
                                <StackPanel Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Fetch Lands" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FetchesCount}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                    <Slider Value="{Binding FetchesCount}" Minimum="0" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Utility -->
                                <StackPanel Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Utility Lands" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding UtilityLandsCount}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                    <Slider Value="{Binding UtilityLandsCount}" Minimum="0" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                </StackPanel>

                                <Separator Background="#2c2e3c" Margin="0,8"/>

                                <!-- Total Lands -->
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Total Lands" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TotalLandsCount, StringFormat='{}{0} / 100 Cards'}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT COLUMN: STATS -->
            <StackPanel Grid.Column="1" Margin="8" VerticalAlignment="Center">
                <!-- Consistency Gauge -->
                <Border Style="{StaticResource ObsidianGlassPanel}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ESTIMATED CONSISTENCY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,24" HorizontalAlignment="Center"/>

                        <Grid Width="140" Height="140" HorizontalAlignment="Center">
                            <Ellipse Stroke="#1c1d24" StrokeThickness="10" Width="130" Height="130"/>
                            <Ellipse Stroke="#3498db" StrokeThickness="10" 
                                     StrokeDashArray="{Binding EstimatedConsistency, Converter={StaticResource PercentToDashConverter}}" 
                                     Width="130" Height="130" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding EstimatedConsistency, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="On Curve" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Color source circles & Warning -->
                <Border Style="{StaticResource ObsidianGlassPanel}" Padding="20">
                    <StackPanel>
                        <TextBlock Text="MANA SOURCE DISTRIBUTION" FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>

                        <!-- Colored dots layout -->
                        <UniformGrid Columns="5" Margin="0,0,0,16">
                            <StackPanel HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#f0f2c5" Margin="0,0,0,4"/>
                                <TextBlock Text="W" FontSize="10" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#3498db" Margin="0,0,0,4"/>
                                <TextBlock Text="U" FontSize="10" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#121212" Stroke="#333" StrokeThickness="1" Margin="0,0,0,4"/>
                                <TextBlock Text="B" FontSize="10" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#e74c3c" Margin="0,0,0,4"/>
                                <TextBlock Text="R" FontSize="10" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#2ecc71" Margin="0,0,0,4"/>
                                <TextBlock Text="G" FontSize="10" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </UniformGrid>

                        <Border CornerRadius="6" Padding="12" Background="#16ff0000" BorderBrush="Red" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="Red" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Warning: Colorless utility land count is high. Consider replacing 2 colorless lands." FontSize="10" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="180"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
