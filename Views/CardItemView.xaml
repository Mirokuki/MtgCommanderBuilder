<UserControl x:Class="MtgCommanderBuilder.Views.CardItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MtgCommanderBuilder.Views"
             mc:Ignorable="d" 
             d:DesignHeight="170" d:DesignWidth="122"
             MouseEnter="UserControl_MouseEnter"
             MouseLeave="UserControl_MouseLeave"
             MouseLeftButtonDown="UserControl_MouseLeftButtonDown">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentGoldBrush" Color="#caa13e"/>
    </UserControl.Resources>

    <Border Name="CardBorder" CornerRadius="8" Background="#121319" BorderThickness="1" BorderBrush="#2c2e3c" Margin="4" Padding="1" ClipToBounds="True" Width="122" Height="170" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Add copy (+1)" Click="Add_Click"/>
                <MenuItem Header="Remove copy (-1)" Click="Remove_Click"/>
                <Separator/>
                <MenuItem Header="Delete Card (All Copies)" Click="RemoveAll_Click" Foreground="Red"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <!-- Dynamic Color-Identity Neon Glow DropShadow -->
            <DropShadowEffect x:Name="GlowEffect" BlurRadius="8" ShadowDepth="0" Opacity="0.0" Direction="0"/>
        </Border.Effect>
        <Grid>
            <!-- 1. Card Image Presenter -->
            <local:CardImagePresenter Card="{Binding}" Width="120" Height="168" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- 2. Live Quantity Badge (Top-Left) -->
            <Border Background="#e6caa13e" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="1" CornerRadius="4" Padding="4,1" Margin="4" VerticalAlignment="Top" HorizontalAlignment="Left" IsHitTestVisible="False">
                <TextBlock Text="{Binding Quantity, StringFormat='{}x{0}'}" FontSize="10" FontWeight="Bold" Foreground="White"/>
            </Border>

            <!-- 3. Price/Info Badge (Bottom-Right) -->
            <Border Background="#cc0d0e12" CornerRadius="4" Padding="4,1" Margin="4" VerticalAlignment="Bottom" HorizontalAlignment="Right" IsHitTestVisible="False">
                <TextBlock Text="{Binding PriceUsd, StringFormat='{} ${0}'}" FontSize="9" FontWeight="Bold" Foreground="#4caf50"/>
            </Border>

            <!-- 4. Hover Controls Overlay (ControlsPanel) -->
            <Border Name="ControlsPanel" Background="#d90d0e12" Visibility="Collapsed" CornerRadius="8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border CornerRadius="15" Background="#33ff0000" BorderBrush="Red" BorderThickness="1" Width="30" Height="30" Margin="0,0,8,0" ToolTip="Remove 1 copy">
                        <Button Click="Remove_Click" Background="Transparent" BorderThickness="0" Foreground="Red" Width="28" Height="28" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <TextBlock Text="&#xE108;" FontFamily="Segoe MDL2 Assets" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Border>
                    <Border CornerRadius="15" Background="#3300ff00" BorderBrush="Green" BorderThickness="1" Width="30" Height="30" ToolTip="Add 1 copy">
                        <Button Click="Add_Click" Background="Transparent" BorderThickness="0" Foreground="Green" Width="28" Height="28" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
