<UserControl x:Class="MtgCommanderBuilder.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MtgCommanderBuilder.Views"
             xmlns:converters="clr-namespace:MtgCommanderBuilder.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <converters:PercentageToStrokeDashArrayConverter x:Key="PercentToDashConverter"/>

        <!-- Slider Style -->
        <Style TargetType="Slider">
            <Setter Property="Background" Value="#1c1d24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#0d0e12" Padding="24">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/> <!-- Left: Sliders List -->
                <ColumnDefinition Width="1*"/>   <!-- Right: Circular completion gauge -->
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: GOALS EDITOR -->
            <Border Grid.Column="0" Style="{StaticResource ObsidianGlassPanel}" Margin="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="DECK GOALS" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Adjust target categories to optimize your build structure" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Scrollable table of sliders -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                        <StackPanel>
                            <!-- Lands Goal -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#2ecc71" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="Lands" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LandsCount, StringFormat='{}{0} Current'}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding LandsGoal}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Slider Value="{Binding LandsGoal}" Minimum="20" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Ramp Goal -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#3498db" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="Ramp Spells" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RampCount, StringFormat='{}{0} Current'}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding RampGoal}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Slider Value="{Binding RampGoal}" Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Card Draw Goal -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#9b59b6" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="Card Draw" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DrawCount, StringFormat='{}{0} Current'}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding DrawGoal}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Slider Value="{Binding DrawGoal}" Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Spot Removal Goal -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#e74c3c" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="Spot Removal" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RemovalCount, StringFormat='{}{0} Current'}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding RemovalGoal}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Slider Value="{Binding RemovalGoal}" Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Board Wipes Goal -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#f1c40f" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="Board Wipes" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding WipeCount, StringFormat='{}{0} Current'}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding WipeGoal}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Slider Value="{Binding WipeGoal}" Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Tutors Goal -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#e67e22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="Tutors" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TutorsCount, StringFormat='{}{0} Current'}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding TutorGoal}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Slider Value="{Binding TutorGoal}" Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Win Conditions Goal -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#1abc9c" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="Win Conditions" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding WinConditionsCount, StringFormat='{}{0} Current'}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding WinConditionGoal}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Slider Value="{Binding WinConditionGoal}" Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,6,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

                <!-- RIGHT COLUMN: COMPLETION GAUGES -->
                <StackPanel Grid.Column="1" Margin="8" VerticalAlignment="Center">
                    <!-- Circular gauge -->
                    <Border Style="{StaticResource ObsidianGlassPanel}" Padding="24" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="DECK COMPLETION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,24" HorizontalAlignment="Center"/>

                            <Grid Width="140" Height="140" HorizontalAlignment="Center">
                                <Ellipse Stroke="#1c1d24" StrokeThickness="10" Width="130" Height="130"/>
                                <Ellipse Stroke="#2ecc71" StrokeThickness="10" 
                                         StrokeDashArray="{Binding GoalsCompletionPercentage, Converter={StaticResource PercentToDashConverter}}" 
                                         Width="130" Height="130" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding GoalsCompletionPercentage, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Complete" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Goal Summary and Alert Box -->
                    <Border Style="{StaticResource ObsidianGlassPanel}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="GOAL SUMMARY" FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                            
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#2ecc71" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="On Target" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="Goals Met" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Grid>

                            <Border CornerRadius="6" Padding="12" Background="#1c1d24" BorderBrush="#2c2e3c" BorderThickness="1" Margin="0,16,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="All goals look good! Keep tuning your deck." FontSize="11" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="180"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
    </Border>
</UserControl>
