<Window x:Class="MtgCommanderBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MtgCommanderBuilder"
        xmlns:vm="clr-namespace:MtgCommanderBuilder.ViewModels"
        xmlns:views="clr-namespace:MtgCommanderBuilder.Views"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="MTG Commander Workspace" 
        Icon="card_back.png"
        WindowState="Maximized"
        Height="850" Width="1350"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ObsidianBackgroundBrush}"
        Foreground="White"
        Loaded="Window_Loaded">

    <Window.Resources>
        <DataTemplate x:Key="CardSlotTemplate">
            <Grid x:Name="PreviewSlotGrid" Margin="0"
                  Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                  Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                
                <Grid x:Name="SlotContentContainer"
                      Width="{Binding DataContext.ProxyPrinter.UnrotatedSlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                      Height="{Binding DataContext.ProxyPrinter.UnrotatedSlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="LayoutTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="0"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.ProxyPrinter.LayoutMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Cricut (6 Cards)">
                                    <Setter Property="LayoutTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="90"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <!-- 1. EMPTY SLOT PLACEHOLDER (Visible only when Card is null) -->
                    <Border Name="EmptySlotBorder" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="1.5" CornerRadius="6" Background="#08caa13e" Cursor="Hand" MouseLeftButtonDown="AddCardToSheet_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource AccentGoldBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="ADD PROXY" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 2. Card Image Presenter (Direct sibling of CardPreviewFrame, rendered behind it to scale up past standard border size without layout constraints) -->
                    <views:CardImagePresenter Card="{Binding}" IsEnabled="False" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Stretch="Fill"
                                              BleedAmount="{Binding DataContext.ProxyPrinter.Bleed, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Width="{Binding DataContext.ProxyPrinter.UnrotatedSlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Height="{Binding DataContext.ProxyPrinter.UnrotatedSlotHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                        <views:CardImagePresenter.Style>
                            <Style TargetType="views:CardImagePresenter">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:CardImagePresenter.Style>
                    </views:CardImagePresenter>

                    <!-- 3. ACTIVE CARD FRAME (Visible only when Card is NOT null) -->
                    <Border Name="CardPreviewFrame" 
                            Width="{Binding DataContext.ProxyPrinter.CardW, RelativeSource={RelativeSource AncestorType=Window}}"
                            Height="{Binding DataContext.ProxyPrinter.CardH, RelativeSource={RelativeSource AncestorType=Window}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1" SnapsToDevicePixels="True" MouseLeftButtonDown="PreviewCard_MouseLeftButtonDown" Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="BorderBrush" Value="Transparent"/> <!-- Transparent by default to avoid accidental borders -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ProxyPrinter.GuideStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="None">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ProxyPrinter.GuideStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="Crop Marks">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ProxyPrinter.GuideStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="Pure Black Borders">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ProxyPrinter.GuideStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="Dashed Margins">
                                        <Setter Property="BorderBrush" Value="Transparent"/> <!-- Handled by internal dashed border overlay -->
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid x:Name="InteractiveCardGrid">
                            <!-- Real-time screen preview dashed margins overlay -->
                            <Rectangle Stroke="{Binding DataContext.ProxyPrinter.GuideColorBrush, RelativeSource={RelativeSource AncestorType=Window}}" StrokeThickness="0.5" StrokeDashArray="4,4" 
                                       Width="{Binding DataContext.ProxyPrinter.CardW, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Height="{Binding DataContext.ProxyPrinter.CardH, RelativeSource={RelativeSource AncestorType=Window}}"
                                       IsHitTestVisible="False" Panel.ZIndex="5">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ProxyPrinter.GuideStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="Dashed Margins">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>

                            <!-- Real-time screen preview solid borders overlay -->
                            <Rectangle Stroke="{Binding DataContext.ProxyPrinter.GuideColorBrush, RelativeSource={RelativeSource AncestorType=Window}}" StrokeThickness="0.5" 
                                       Width="{Binding DataContext.ProxyPrinter.CardW, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Height="{Binding DataContext.ProxyPrinter.CardH, RelativeSource={RelativeSource AncestorType=Window}}"
                                       IsHitTestVisible="False" Panel.ZIndex="5">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ProxyPrinter.GuideStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="Pure Black Borders">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>


                            <!-- Dynamic Quantity Badge top-left (e.g. 2x) -->
                            <Border Panel.ZIndex="10" Margin="4" CornerRadius="10" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Background="{StaticResource AccentGoldBrush}" BorderBrush="Black" BorderThickness="1">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="Black">
                                    <TextBlock.Text>
                                        <Binding Path="Quantity" StringFormat="{}{0}x"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>

                            <!-- Hover Action Overlay (fades in on hover) -->
                            <Border Name="PreviewHoverOverlay" Panel.ZIndex="10" Background="#d9111218" CornerRadius="2" Opacity="0" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=InteractiveCardGrid, Path=IsMouseOver}" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>    <!-- Top part for spacing -->
                                        <RowDefinition Height="Auto"/> <!-- Bottom toolbar controls -->
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource AccentGoldBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="DOUBLE-CLICK" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="to select &amp; swap art" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Quantity increment / decrement / remove row -->
                                    <Border Grid.Row="1" Background="#f21b1c24" BorderBrush="#2d2f3d" BorderThickness="0,1,0,0" Padding="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>   <!-- Decr [-] -->
                                                <ColumnDefinition Width="*"/>   <!-- Incr [+] -->
                                                <ColumnDefinition Width="Auto"/> <!-- Delete [x] -->
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" Click="PreviewQtyDecrement_Click" Height="26" Margin="2,0" Padding="0" Background="#2c2e3c" Foreground="White" BorderThickness="0" ToolTip="Reduce print copies">
                                                <TextBlock Text="&#xE108;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>

                                            <Button Grid.Column="1" Click="PreviewQtyIncrement_Click" Height="26" Margin="2,0" Padding="0" Background="#2c2e3c" Foreground="White" BorderThickness="0" ToolTip="Increase print copies">
                                                <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>

                                            <Button Grid.Column="2" Click="PreviewQtyRemove_Click" Width="26" Height="26" Margin="2,0" Padding="0" Background="#33ff0000" Foreground="Red" BorderBrush="Red" BorderThickness="1" ToolTip="Remove from print sheet">
                                                <TextBlock Text="&#xE10A;" FontFamily="Segoe MDL2 Assets" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>
        <Style x:Key="SidebarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1c1d24"/>
            <Setter Property="Foreground" Value="#8c949b"/>
            <Setter Property="BorderBrush" Value="#2c2e3c"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter TargetName="border" Property="Background" Value="#252731"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#272115"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentGoldBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentGoldBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1c1d24"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2c2e3c"/>
                                <Setter Property="Foreground" Value="#555768"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    
        <!-- Sidebar Navigation RadioButton Style -->
        <Style x:Key="SidebarNavigationRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8c949b"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="GroupName" Value="SidebarNav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{TemplateBinding Foreground}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#17181f"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5c2bb0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Navigation Button Style -->
        <Style x:Key="SidebarNavigationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8c949b"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{TemplateBinding Foreground}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#17181f"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Centered TextBlock Style for DataGrid columns -->
        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Theme & Power Card Radio Button Style -->
        <Style x:Key="ThemeSelectRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="#121319" BorderBrush="#2c2e3c" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="6" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1c1d24"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5c2bb0"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8a53e6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Strategy Toggle Button Style -->
        <Style x:Key="StrategySelectToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="#121319" BorderBrush="#2c2e3c" BorderThickness="1" CornerRadius="6" Padding="10,12" Margin="4" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1c1d24"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5c2bb0"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8a53e6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/> <!-- Column 0: Left Navigation Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Column 1: Main Content Viewport -->
        </Grid.ColumnDefinitions>

        <!-- COLUMN 0: LEFT NAVIGATION SIDEBAR -->
        <Border Grid.Column="0" Background="#090a0f" BorderBrush="#20222a" BorderThickness="0,0,1,0">
            <Grid Margin="16,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- App Logo / Title -->
                    <RowDefinition Height="*"/>    <!-- Scrollable Navigation -->
                    <RowDefinition Height="Auto"/> <!-- Footer Navigation -->
                </Grid.RowDefinitions>

                <!-- App Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,0,0,24">
                    <TextBlock Text="&#xE704;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource AccentGoldBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="MTG Deck Builder" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Scrollable Navigation Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Decks Section Header -->
                        <TextBlock Text="DECKS" FontSize="10" FontWeight="Bold" Foreground="#56596e" Margin="8,0,0,8"/>

                        <!-- Decks ListBox -->
                        <ListBox ItemsSource="{Binding SavedDecks}" SelectedItem="{Binding SelectedDeck, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Margin="0,0,0,8"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#8c949b"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#17181f"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#5c2bb0"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ClipToBounds="True" Height="20" Background="Transparent" MouseEnter="DeckName_MouseEnter" MouseLeave="DeckName_MouseLeave">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock x:Name="DeckNameTextBlock" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.RenderTransform>
                                                    <TranslateTransform x:Name="TextTranslate"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- "+ New Deck" Button -->
                        <Button Command="{Binding CreateNewDeckCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderBrush="Transparent" Foreground="#8c949b" Padding="8,8" Margin="0,0,0,24">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#8c949b" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="New Deck" FontSize="12" FontWeight="SemiBold" Foreground="#8c949b" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#17181f"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Background="#20222a" Margin="0,0,0,16"/>

                        <!-- Navigation Items -->
                        <RadioButton Content="DECKS" Tag="&#xE8F1;" IsChecked="True" Style="{StaticResource SidebarNavigationRadioButtonStyle}" Click="NavButton_Click" CommandParameter="DeckBuilder"/>
                        <RadioButton Content="DECK WIZARD" Tag="&#xE74E;" Style="{StaticResource SidebarNavigationRadioButtonStyle}" Click="NavButton_Click" CommandParameter="Wizard"/>
                        <Button Content="GOALS" Tag="&#xE102;" Style="{StaticResource SidebarNavigationButtonStyle}" Click="OpenGoals_Click"/>
                        <Button Content="MANA DESIGNER" Tag="&#xE9D2;" Style="{StaticResource SidebarNavigationButtonStyle}" Click="OpenManaDesigner_Click"/>
                        <Button Content="RECOMMENDATIONS" Tag="&#xE1F6;" Style="{StaticResource SidebarNavigationButtonStyle}" Click="OpenRecommendations_Click"/>
                        <RadioButton Content="ANALYTICS" Tag="&#xE9D2;" Style="{StaticResource SidebarNavigationRadioButtonStyle}" Click="NavButton_Click" CommandParameter="Analytics"/>
                        <RadioButton Content="PROXY PRINTER" Tag="&#xE749;" Style="{StaticResource SidebarNavigationRadioButtonStyle}" Click="NavButton_Click" CommandParameter="ProxyPrinter"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Navigation -->
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <Separator Background="#20222a" Margin="0,0,0,16"/>
                    <RadioButton Content="Settings" Tag="&#xE713;" Style="{StaticResource SidebarNavigationRadioButtonStyle}" Click="NavButton_Click" CommandParameter="Settings"/>
                    <Button Content="Help &amp; Feedback" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderBrush="Transparent" Foreground="#8c949b" Padding="8,8" Click="SyntaxGuide_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#8c949b" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Help &amp; Feedback" FontSize="12" FontWeight="SemiBold" Foreground="#8c949b" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#17181f"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- COLUMN 1: MAIN VIEWPORT FRAME -->
        <Grid Grid.Column="1">
            <!-- 1. DECK WORKSPACE VIEW (ActiveView == 'DeckBuilder') -->
            <Grid Visibility="{Binding ActiveView, Converter={StaticResource StringEqualToVisibilityConverter}, ConverterParameter=DeckBuilder}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Deck Header -->
                    <RowDefinition Height="*"/>    <!-- Deck View Tabs -->
                    <RowDefinition Height="Auto"/> <!-- Status Bar -->
                </Grid.RowDefinitions>

                <!-- Deck Header Panel -->
                <Border Grid.Row="0" Background="#111218" SnapsToDevicePixels="True" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ActiveDeckViewModel.Name}" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <!-- Edit Icon button -->
                                <Button Click="RenameDeck_Click" Background="Transparent" BorderBrush="Transparent" Padding="4" Margin="8,0,0,0" VerticalAlignment="Center" ToolTip="Rename Deck">
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="Commander / EDH" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="2,2,0,0"/>
                        </StackPanel>

                        <!-- Metrics & Save Actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActiveDeckViewModel.DeckSize, StringFormat='{}{0} / 100'}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                <TextBlock Text="Cards" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActiveDeckViewModel.TotalPriceUsd, StringFormat='{}{0:C}'}" FontSize="14" FontWeight="Bold" Foreground="#4caf50" HorizontalAlignment="Right"/>
                                <TextBlock Text="Est. Price" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                            </StackPanel>

                            <!-- Save Button -->
                            <Button Click="SaveDeck_Click" Background="#5c2bb0" Foreground="White" BorderThickness="0" Padding="16,10" FontWeight="SemiBold" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE105;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Save Deck" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <!-- Context Ellipsis Button -->
                            <Button Click="ContextButton_Click" Width="38" Height="38" Background="#1c1d24" BorderBrush="#2c2e3c" BorderThickness="1" Padding="0" Margin="0,0,8,0">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Import Deck Text..." Click="Import_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Import Deck File..." Click="ImportFile_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets"/></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Export Deck Text..." Click="Export_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE8B6;" FontFamily="Segoe MDL2 Assets"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Export Moxfield..." Click="ExportMoxfield_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Export MPC XML..." Click="ExportMpcXml_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE105;" FontFamily="Segoe MDL2 Assets"/></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Sync from Scryfall (Offline Setup)" Command="{Binding DownloadDatabaseCommand}">
                                            <MenuItem.Icon><TextBlock Text="&#xE117;" FontFamily="Segoe MDL2 Assets"/></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Delete Current Deck" Command="{Binding DeleteDeckCommand}" CommandParameter="{Binding ActiveDeckViewModel.ActiveDeck}" Foreground="Red">
                                            <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="Red"/></MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <TextBlock Text="&#xE10C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <!-- Toggle Left Sidebar (Search Panel) -->
                            <ToggleButton x:Name="ToggleLeftSidebarBtn" Click="ToggleLeftSidebar_Click" IsChecked="True" Style="{StaticResource SidebarToggleButtonStyle}" Width="38" Height="38" Margin="0,0,8,0" ToolTip="Toggle Left Search Panel">
                                <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </ToggleButton>

                            <!-- Toggle Right Sidebar (Stats Panel) -->
                            <ToggleButton x:Name="ToggleRightSidebarBtn" Click="ToggleRightSidebar_Click" IsChecked="True" Style="{StaticResource SidebarToggleButtonStyle}" Width="38" Height="38" ToolTip="Toggle Right Stats Panel">
                                <TextBlock Text="&#xE111;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Deck View TabControl -->
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0" Margin="0" x:Name="MainTabControl">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#8c949b"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="20,10"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#17181f"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#5c2bb0"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- TAB 1: DECK VIEW -->
                    <TabItem Header="Deck View">
                        <Grid Background="{StaticResource ObsidianBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LeftActiveDeckColumn" Width="320"/> <!-- Column 0: Left Search Panel -->
                        <ColumnDefinition Width="*"/>   <!-- Column 1: Center Active Deck List -->
                        <ColumnDefinition x:Name="RightStatsColumn" Width="340"/> <!-- Column 2: Right Commander & stats sidebar -->
                    </Grid.ColumnDefinitions>

            <!-- ================= COLUMN 0: ACTIVE DECK SIDEBAR ================= -->
            <Border x:Name="LeftActiveDeckBorder" Grid.Column="1" Style="{StaticResource ObsidianGlassPanel}" Margin="16,16" Padding="14,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Active Deck Selection Dropdown -->
                        <RowDefinition Height="Auto"/> <!-- Live Size & Name edit -->
                        <RowDefinition Height="*"/>    <!-- Scrollable Grouped Card lists -->
                    </Grid.RowDefinitions>

                    <!-- Active Deck Selector Dropdown -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="SELECT DECK" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SavedDecks}" SelectedItem="{Binding SelectedDeck, Mode=TwoWay}" DisplayMemberPath="Name"/>
                    </StackPanel>

                    <!-- Active Deck Info Header -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock Text="RENAME DECK" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding ActiveDeckViewModel.Name, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="18" 
                                 FontWeight="Bold" 
                                 Background="Transparent" 
                                 BorderThickness="0,0,0,1" 
                                 BorderBrush="#2d2f3d" 
                                 Padding="0,4"
                                 Foreground="White"
                                 Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{StaticResource AccentGoldBrush}"/>
                            <TextBlock Text="{Binding ActiveDeckViewModel.DeckSize, StringFormat='{}{0} / 100 Cards'}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="GROUP BY" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                <ComboBox Height="40" FontSize="11" VerticalContentAlignment="Center" Padding="8,0,28,0"
                                          ItemsSource="{Binding ActiveDeckViewModel.GroupModes}"
                                          SelectedItem="{Binding ActiveDeckViewModel.SelectedGroupMode, Mode=TwoWay}"
                                          Background="#121319" Foreground="White" BorderBrush="#2c2e3c"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="SORT BY" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                <ComboBox Height="40" FontSize="11" VerticalContentAlignment="Center" Padding="8,0,28,0"
                                          ItemsSource="{Binding ActiveDeckViewModel.SortOrders}"
                                          SelectedItem="{Binding ActiveDeckViewModel.CurrentSortOrder, Mode=TwoWay}"
                                          Background="#121319" Foreground="White" BorderBrush="#2c2e3c"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Scrollable Grouped lists -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,4,0" DataContext="{Binding ActiveDeckViewModel}">
                            
                            <!-- COMMANDER GROUP -->
                            <Expander IsExpanded="True" Margin="0,0,0,8" Background="#16171e" BorderBrush="#2c2e3c">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Commander" FontWeight="Bold" FontSize="13" Foreground="#66b3ff"/>
                                        <TextBlock Text="{Binding CommanderCount, StringFormat=' ({0})'}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="11"/>
                                    </StackPanel>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding CommanderList}" Margin="4">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <views:CardItemView Margin="2" ToolTipService.InitialShowDelay="100"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>

                            <!-- DYNAMIC GROUPS -->
                            <ItemsControl ItemsSource="{Binding Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="True" Margin="0,0,0,8" Background="#16171e" BorderBrush="#2c2e3c">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding GroupName}" FontWeight="Bold" FontSize="13" Foreground="{Binding HeaderBrush}"/>
                                                    <TextBlock Text="{Binding Count, StringFormat=' ({0})'}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="11"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <ItemsControl ItemsSource="{Binding Cards}" Margin="4">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <views:CardItemView Margin="2" ToolTipService.InitialShowDelay="100"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ================= COLUMN 1: CENTER SEARCH ENGINE & INSPECTOR ================= -->
            <Grid x:Name="LeftSearchPanelGrid" Grid.Column="0" Margin="20,16,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Search & Filters Box -->
                    <RowDefinition Height="*"/>    <!-- Split search results and Card Inspector -->
                </Grid.RowDefinitions>

                <!-- Search control box -->
                <Border Grid.Row="0" Style="{StaticResource ObsidianGlassPanel}" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel DataContext="{Binding CardSearchViewModel}">
                        <!-- 1. OFFLINE SEARCH ENGINE -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="OFFLINE SEARCH ENGINE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="2,0,0,4"/>
                            <TextBox x:Name="SearchTextBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="14" Padding="10,8" Background="#0b0c10"/>
                        </StackPanel>

                        <!-- 2. ORACLE RULES TEXT -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="ORACLE RULES TEXT" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="2,0,0,4"/>
                            <TextBox Text="{Binding OracleSearch, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Background="#0b0c10"/>
                        </StackPanel>

                        <!-- 3. CARD TYPE -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="CARD TYPE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="2,0,0,4"/>
                            <ComboBox ItemsSource="{Binding CardTypes}" SelectedItem="{Binding SelectedType}" Height="34"/>
                        </StackPanel>

                        <!-- 4. SORT BY -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="SORT BY" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="2,0,0,4"/>
                            <ComboBox ItemsSource="{Binding SortOrders}" SelectedItem="{Binding SortOrder}" Height="34"/>
                        </StackPanel>

                        <!-- 5. Options: Checkbox and Zoom Slider -->
                        <StackPanel Orientation="Horizontal" Margin="2,4,0,0" VerticalAlignment="Center">
                            <!-- Search Affects Staples toggle -->
                            <CheckBox IsChecked="{Binding SearchAffectsStaples, Mode=TwoWay}" 
                                      Content="Search Filters Staples" 
                                      FontSize="11" FontWeight="SemiBold" Margin="0,0,24,0"
                                      ToolTip="Applies search query, card type, and oracle filters to the Staples tab as well"/>

                            <!-- Card Size Zoom Slider -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider x:Name="CardSizeSlider" Minimum="0.6" Maximum="2.0" Value="{Binding CardGridScale, Mode=TwoWay}" Width="100" TickFrequency="0.1" IsSnapToTickEnabled="False" VerticalAlignment="Center" ToolTip="Grid Card Zoom"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Two-Pane Split results / Inspector -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>   <!-- Sub-Column 0: Results (Dynamic, fills remaining space) -->
                        <ColumnDefinition Width="300"/> <!-- Sub-Column 1: Inspector (Fixed width for absolute layout stability) -->
                    </Grid.ColumnDefinitions>

                    <!-- Tabbed Results Selector -->
                    <TabControl Grid.Column="0" Background="Transparent" BorderThickness="0" Margin="0,0,16,0">
                        
                        <!-- SEARCH RESULTS TAB -->
                        <TabItem Header="Search Results">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,3">
                                        <TextBlock Text="Search Results" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=DataContext.CardSearchViewModel.SearchResults.Count, StringFormat=' ({0})'}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="10" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>

                            <Border Background="#121319" BorderBrush="#2c2e3c" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="8">
                                <Grid>
                                    <!-- IMAGE GRID LIST BOX -->
                                    <ListBox ItemsSource="{Binding CardSearchViewModel.SearchResults}" 
                                             Background="Transparent" 
                                             BorderThickness="0" 
                                             SelectionChanged="ListBox_SelectionChanged"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <EventSetter Event="MouseDoubleClick" Handler="CardGridItem_MouseDoubleClick"/>
                                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="CardGridItem_PreviewMouseRightButtonDown"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="6" Style="{StaticResource MtgCardBorder}" Width="122" Height="170" CornerRadius="8" Padding="1" ClipToBounds="True">
                                                    <Border.LayoutTransform>
                                                        <ScaleTransform ScaleX="{Binding DataContext.CardSearchViewModel.CardGridScale, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                                        ScaleY="{Binding DataContext.CardSearchViewModel.CardGridScale, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    </Border.LayoutTransform>
                                                    <Grid x:Name="SearchResultsCardGrid">
                                                        <!-- Card Image Presenter -->
                                                        <views:CardImagePresenter Card="{Binding}" Width="120" Height="168"/>

                                                        <!-- Live Quantity Badge top-left -->
                                                        <Border Name="GridStatusBadge" Panel.ZIndex="10" Margin="4" CornerRadius="4" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Left" BorderThickness="1">
                                                            <Border.Tag>
                                                                <MultiBinding Converter="{StaticResource CardDeckStatusConverter}">
                                                                    <Binding />
                                                                    <Binding Path="DataContext.ActiveDeckViewModel.Cards" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    <Binding Path="DataContext.ActiveDeckViewModel.Commander" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </Border.Tag>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Background" Value="#e6caa13e"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentGoldBrush}"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Tag" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </Trigger>
                                                                        <Trigger Property="Tag" Value="COMMANDER">
                                                                            <Setter Property="Background" Value="#330e68ab"/>
                                                                            <Setter Property="BorderBrush" Value="#0e68ab"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <TextBlock Text="{Binding ElementName=GridStatusBadge, Path=Tag}" FontSize="7" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ElementName=GridStatusBadge, Path=Tag}" Value="COMMANDER">
                                                                                <Setter Property="Foreground" Value="#66b3ff"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </TabItem>

                        <!-- STAPLES TAB -->
                        <TabItem Header="Staples Selector">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,3">
                                        <TextBlock Text="Staples" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>

                            <Border Background="#121319" BorderBrush="#2c2e3c" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- STAPLES CUSTOM CATEGORY MANAGEMENT HEADER -->
                                    <Border Grid.Row="0" Background="#1a1c24" BorderBrush="#2c2e3c" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Dropdown label -->
                                            <TextBlock Grid.Column="0" Text="Staples list:" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0"/>

                                            <!-- The Dropdown -->
                                            <ComboBox Grid.Column="1" x:Name="StaplesCategoryComboBox"
                                                      ItemsSource="{Binding CardSearchViewModel.StaplesCategories}"
                                                      SelectedItem="{Binding CardSearchViewModel.SelectedStaplesCategory, Mode=TwoWay}"
                                                      Background="#0f1015" Foreground="White" BorderBrush="#2c2e3c" Height="32" VerticalContentAlignment="Center" FontSize="13" MinWidth="180" Padding="8,3,24,3">
                                                <ComboBox.Resources>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0f1015" />
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#caa13e" />
                                                </ComboBox.Resources>
                                            </ComboBox>

                                            <!-- Create Category Button -->
                                            <Button Grid.Column="2" Click="CreateCustomStaplesTab_Click" ToolTip="Create a new custom Staples tab"
                                                    Margin="8,0,0,0" Padding="10,0" Height="32" Background="#2c2e3c" BorderBrush="#2c2e3c" Foreground="White" FontSize="11" FontWeight="SemiBold">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="10"/>
                                                    <TextBlock Text="New" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Add Selected Card to Custom Staples Button -->
                                            <Button Grid.Column="3" Click="AddSelectedToStaples_Click" ToolTip="Add currently selected card from Search to this Staples category"
                                                    Margin="8,0,0,0" Padding="10,0" Height="32" Background="#caa13e" BorderBrush="#caa13e" Foreground="Black" FontSize="11" FontWeight="Bold"
                                                    Visibility="{Binding CardSearchViewModel.IsCustomTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Foreground="Black" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="10"/>
                                                    <TextBlock Text="Add Selected Card" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Rename Button -->
                                            <Button Grid.Column="4" Click="RenameCustomStaplesTab_Click" ToolTip="Rename current custom Staples tab"
                                                    Margin="8,0,0,0" Padding="10,0" Height="32" Background="#22232a" BorderBrush="#2c2e3c" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                    Visibility="{Binding CardSearchViewModel.IsCustomTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="10"/>
                                                    <TextBlock Text="Rename" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Delete Button -->
                                            <Button Grid.Column="5" Click="DeleteCustomStaplesTab_Click" ToolTip="Delete current custom Staples tab"
                                                    Margin="8,0,0,0" Padding="10,0" Height="32" Background="#33ff0000" BorderBrush="Red" Foreground="Red" FontSize="11" FontWeight="SemiBold"
                                                    Visibility="{Binding CardSearchViewModel.IsCustomTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="10"/>
                                                    <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- IMAGE GRID LIST BOX -->
                                    <ListBox Grid.Row="1" ItemsSource="{Binding CardSearchViewModel.Staples}" 
                                             Background="Transparent" 
                                             BorderThickness="0" 
                                             SelectionChanged="ListBox_SelectionChanged"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <EventSetter Event="MouseDoubleClick" Handler="CardGridItem_MouseDoubleClick"/>
                                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="CardGridItem_PreviewMouseRightButtonDown"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="6" Style="{StaticResource MtgCardBorder}" Width="122" Height="170" CornerRadius="8" Padding="1" ClipToBounds="True">
                                                     <Border.LayoutTransform>
                                                         <ScaleTransform ScaleX="{Binding DataContext.CardSearchViewModel.CardGridScale, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                                         ScaleY="{Binding DataContext.CardSearchViewModel.CardGridScale, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                     </Border.LayoutTransform>
                                                    <Grid x:Name="CardGrid">
                                                        <!-- Card Image Presenter -->
                                                         <!-- Custom Staples Delete Overlay Button top-right -->
                                                         <Button Click="RemoveFromCustomStaples_Click"
                                                                 ToolTip="Remove card from this Staples category"
                                                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                 Margin="0,4,4,0" Width="18" Height="18" Padding="0"
                                                                 Background="#b3ff0000" BorderThickness="0" Foreground="White" Panel.ZIndex="10"
                                                                 Visibility="{Binding DataContext.CardSearchViewModel.IsCustomTabSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                             <Button.Resources>
                                                                 <Style TargetType="Border">
                                                                     <Setter Property="CornerRadius" Value="9"/>
                                                                 </Style>
                                                             </Button.Resources>
                                                             <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                         </Button>
                                                        <views:CardImagePresenter Card="{Binding}" Width="120" Height="168"/>

                                                        <!-- Live Quantity Badge top-left -->
                                                        <Border Name="StaplesGridStatusBadge" Panel.ZIndex="10" Margin="4" CornerRadius="4" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Left" BorderThickness="1">
                                                            <Border.Tag>
                                                                <MultiBinding Converter="{StaticResource CardDeckStatusConverter}">
                                                                    <Binding />
                                                                    <Binding Path="DataContext.ActiveDeckViewModel.Cards" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    <Binding Path="DataContext.ActiveDeckViewModel.Commander" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </Border.Tag>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Background" Value="#e6caa13e"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentGoldBrush}"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Tag" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </Trigger>
                                                                        <Trigger Property="Tag" Value="COMMANDER">
                                                                            <Setter Property="Background" Value="#330e68ab"/>
                                                                            <Setter Property="BorderBrush" Value="#0e68ab"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <TextBlock Text="{Binding ElementName=StaplesGridStatusBadge, Path=Tag}" FontSize="7" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ElementName=StaplesGridStatusBadge, Path=Tag}" Value="COMMANDER">
                                                                                <Setter Property="Foreground" Value="#66b3ff"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </TabItem>

                        <!-- MY DECK TAB -->
                        <TabItem Header="My Deck">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,3">
                                        <TextBlock Text="My Deck" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Path=DataContext.ActiveDeckViewModel.DeckSize, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=' ({0})'}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="10" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>

                            <Border Background="#121319" BorderBrush="#2c2e3c" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="8">
                                <Grid>
                                    <!-- IMAGE GRID VIEW -->
                                    <ListBox ItemsSource="{Binding ActiveDeckViewModel.Cards}" 
                                             Background="Transparent" 
                                             BorderThickness="0" 
                                             SelectionChanged="ListBox_SelectionChanged"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <EventSetter Event="MouseDoubleClick" Handler="CardGridItem_MouseDoubleClick"/>
                                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="CardGridItem_PreviewMouseRightButtonDown"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="6" Style="{StaticResource MtgCardBorder}" Width="122" Height="170" CornerRadius="8" Padding="1" ClipToBounds="True">
                                                    <Border.LayoutTransform>
                                                        <ScaleTransform ScaleX="{Binding DataContext.CardSearchViewModel.CardGridScale, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                                        ScaleY="{Binding DataContext.CardSearchViewModel.CardGridScale, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    </Border.LayoutTransform>
                                                    <Grid x:Name="DeckCardGrid">
                                                        <views:CardImagePresenter Card="{Binding}" Width="120" Height="168"/>

                                                        <!-- Quantity Badge top-left -->
                                                        <Border Panel.ZIndex="10" Margin="4" CornerRadius="4" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#e6caa13e" BorderThickness="1" BorderBrush="{StaticResource AccentGoldBrush}">
                                                            <TextBlock Text="{Binding Quantity, StringFormat='{}{0}x'}" FontSize="8" FontWeight="Bold" Foreground="Black"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </TabItem>
                    </TabControl>

                    <!-- CARD PREVIEW INSPECTOR PANEL -->
                    <Border Grid.Column="1" Style="{StaticResource ObsidianGlassPanel}">
                        <Grid>
                            <!-- No selection layout -->
                            <Grid Name="NoSelectionPanel" Visibility="Visible">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE830;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="SELECT A CARD TO INSPECT" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Click any card item" FontSize="10" Foreground="#5a5d70" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- Selection layout -->
                            <Grid Name="SelectionPanel" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Artwork preview -->
                                    <RowDefinition Height="*"/>    <!-- Text attributes -->
                                    <RowDefinition Height="Auto"/> <!-- Button panel actions -->
                                </Grid.RowDefinitions>

                                <!-- Large visual card container -->
                                <Border Grid.Row="0" CornerRadius="8" ClipToBounds="True" Height="340" Width="244" HorizontalAlignment="Center" Background="#0b0c10" Margin="0,0,0,12">
                                    <views:CardImagePresenter x:Name="InspectorImage" Width="Auto" Height="Auto"/>
                                </Border>

                                 <!-- text stats descriptions -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="InspectorName" Text="Card Name" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="InspectorType" Text="Creature - Goblin" FontSize="11" Foreground="{StaticResource AccentGoldBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        
                                        <Border Background="#121319" CornerRadius="6" Padding="8" Margin="0,0,0,10" BorderBrush="#2c2e3c" BorderThickness="1">
                                            <TextBlock x:Name="InspectorText" Text="Oracle Rules Text" FontSize="11" Foreground="White" TextWrapping="Wrap" LineHeight="16"/>
                                        </Border>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Mana Value (CMC)" FontSize="9" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock x:Name="InspectorCmc" Text="3" FontSize="13" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Market Price" FontSize="9" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock x:Name="InspectorPrice" Text="$0.25" FontSize="13" FontWeight="SemiBold" Foreground="#4caf50"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Printing Selection -->
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Text="Card Printing Edition" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="PrintingsComboBox" Background="#121319" Foreground="White" BorderBrush="#2c2e3c"
                                                      SelectionChanged="PrintingsComboBox_SelectionChanged" Height="36" FontSize="11">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/> <!-- Set Code -->
                                                                <ColumnDefinition Width="*"/>    <!-- Set Name -->
                                                                <ColumnDefinition Width="Auto"/> <!-- Price -->
                                                            </Grid.ColumnDefinitions>
                                                            <Border Background="#222430" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding SetDisplay}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding SetName}" TextTrimming="CharacterEllipsis" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding PriceDisplay, StringFormat='{} ({0})'}" FontSize="11" Foreground="#4caf50" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Custom Categories Tagging -->
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Text="Categories (comma separated)" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="CategoriesTextBox" Background="#121319" Foreground="White" BorderBrush="#2c2e3c"
                                                     Padding="6,6" FontSize="11" Height="28"
                                                     LostFocus="CategoriesTextBox_LostFocus" KeyDown="CategoriesTextBox_KeyDown"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                 <!-- Button Panel Actions -->
                                 <UniformGrid x:Name="InspectorActionPanel" Grid.Row="2" Columns="2" Height="36">
                                     <Button x:Name="InspectorAddToDeckBtn" Click="AddToDeck_Click" HorizontalAlignment="Stretch" Margin="2,0">
                                         <StackPanel Orientation="Horizontal">
                                             <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                             <TextBlock Text="Add to Deck" VerticalAlignment="Center" FontSize="11"/>
                                         </StackPanel>
                                     </Button>
                                     
                                     <Button x:Name="InspectorRemoveFromDeckBtn" Click="RemoveFromDeck_Click" HorizontalAlignment="Stretch" Margin="2,0" Background="#d3202a" Foreground="White" BorderThickness="0">
                                         <StackPanel Orientation="Horizontal">
                                             <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="White"/>
                                             <TextBlock Text="Remove from Deck" VerticalAlignment="Center" FontSize="11" Foreground="White"/>
                                         </StackPanel>
                                     </Button>
                                     
                                     <Button x:Name="InspectorSetCommanderBtn" Click="SetCommander_Click" HorizontalAlignment="Stretch" Margin="2,0" Background="#caa13e" Foreground="Black" BorderThickness="0">
                                         <StackPanel Orientation="Horizontal">
                                             <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="Black"/>
                                             <TextBlock Text="Set Commander" VerticalAlignment="Center" FontSize="11" Foreground="Black"/>
                                         </StackPanel>
                                     </Button>
                                 </UniformGrid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <!-- ================= COLUMN 2: COMMANDER, STATS, & LAND HELPER ================= -->
            <Border x:Name="RightStatsBorder" Grid.Column="2" Style="{StaticResource ObsidianGlassPanel}" Margin="0,16,20,16" Padding="14,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title: Live Analysis -->
                        <RowDefinition Height="*"/>    <!-- Scrollable content -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="LIVE ANALYSIS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- 1. DECK SCORE GAUGE -->
                            <TextBlock Text="Deck Score" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                            <Grid Width="110" Height="110" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Ellipse Stroke="#1c1d24" StrokeThickness="8" Width="100" Height="100"/>
                                <Ellipse Stroke="#2ecc71" StrokeThickness="8" StrokeDashArray="26.86, 8.48" Width="100" Height="100" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="76" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Very Strong" FontSize="9" FontWeight="SemiBold" Foreground="#2ecc71" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#20222a" Margin="0,0,0,16"/>

                            <!-- 2. MINI MANA CURVE -->
                            <TextBlock Text="Mana Curve" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="80"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <UniformGrid Grid.Row="0" Columns="8" VerticalAlignment="Bottom" Height="80">
                                    <views:CurveBar ValueCount="0" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="0" DataContext="{Binding ActiveDeckViewModel}"/>
                                    <views:CurveBar ValueCount="1" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="1" DataContext="{Binding ActiveDeckViewModel}"/>
                                    <views:CurveBar ValueCount="2" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="2" DataContext="{Binding ActiveDeckViewModel}"/>
                                    <views:CurveBar ValueCount="3" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="3" DataContext="{Binding ActiveDeckViewModel}"/>
                                    <views:CurveBar ValueCount="4" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="4" DataContext="{Binding ActiveDeckViewModel}"/>
                                    <views:CurveBar ValueCount="5" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="5" DataContext="{Binding ActiveDeckViewModel}"/>
                                    <views:CurveBar ValueCount="6" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="6" DataContext="{Binding ActiveDeckViewModel}"/>
                                    <views:CurveBar ValueCount="7" MaxCount="{Binding ActiveDeckViewModel.MaxCmcCount}" Title="7+" DataContext="{Binding ActiveDeckViewModel}"/>
                                </UniformGrid>
                                <UniformGrid Grid.Row="1" Columns="8" Margin="0,4,0,0">
                                    <TextBlock Text="0" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="1" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="2" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="3" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="4" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="5" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="6" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="7+" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </UniformGrid>
                            </Grid>

                            <Separator Background="#20222a" Margin="0,0,0,16"/>

                            <!-- 3. COLOR IDENTITY -->
                            <TextBlock Text="Color Identity" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                            <Grid Width="90" Height="90" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Ellipse Stroke="#1c1d24" StrokeThickness="8" Width="80" Height="80"/>
                                <Grid>
                                    <TextBlock Text="{Binding ActiveDeckViewModel.ColorIdentityText}" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    
                                    <!-- White (W) -->
                                    <Ellipse Fill="#f0f2c5" Width="14" Height="14" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0.15"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveDeckViewModel.HasWhite}" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <!-- Blue (U) -->
                                    <Ellipse Fill="#3498db" Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0.15"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveDeckViewModel.HasBlue}" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <!-- Black (B) -->
                                    <Ellipse Fill="#121212" Stroke="#333" StrokeThickness="1" Width="14" Height="14" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,18,6">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0.15"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveDeckViewModel.HasBlack}" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <!-- Red (R) -->
                                    <Ellipse Fill="#e74c3c" Width="14" Height="14" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="18,0,0,6">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0.15"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveDeckViewModel.HasRed}" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <!-- Green (G) -->
                                    <Ellipse Fill="#2ecc71" Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="4,0,0,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0.15"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveDeckViewModel.HasGreen}" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Grid>

                            <Separator Background="#20222a" Margin="0,0,0,16"/>

                            <!-- 4. GOALS STATUS TRACKER -->
                            <TextBlock Text="Goal Status Tracker" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                            <StackPanel Margin="0,0,0,10">
                                <!-- Lands Goal Tracker -->
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Lands" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActiveDeckViewModel.LandsCount, StringFormat='{}{0}'}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.LandsGoal, StringFormat='/ {0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,0"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.LandsStatus, StringFormat=' ({0})'}" Foreground="{Binding ActiveDeckViewModel.LandsStatusBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding ActiveDeckViewModel.LandsCount, Mode=OneWay}" Maximum="{Binding ActiveDeckViewModel.LandsGoal}" Height="4" Foreground="{Binding ActiveDeckViewModel.LandsStatusBrush}" Background="#1c1d24" BorderThickness="0" Margin="0,4,0,6"/>
                                </StackPanel>

                                <!-- Ramp Goal Tracker -->
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Ramp" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActiveDeckViewModel.RampCount, StringFormat='{}{0}'}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.RampGoal, StringFormat='/ {0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,0"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.RampStatus, StringFormat=' ({0})'}" Foreground="{Binding ActiveDeckViewModel.RampStatusBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding ActiveDeckViewModel.RampCount, Mode=OneWay}" Maximum="{Binding ActiveDeckViewModel.RampGoal}" Height="4" Foreground="{Binding ActiveDeckViewModel.RampStatusBrush}" Background="#1c1d24" BorderThickness="0" Margin="0,4,0,6"/>
                                </StackPanel>

                                <!-- Card Draw Goal Tracker -->
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Card Draw" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActiveDeckViewModel.DrawCount, StringFormat='{}{0}'}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.DrawGoal, StringFormat='/ {0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,0"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.DrawStatus, StringFormat=' ({0})'}" Foreground="{Binding ActiveDeckViewModel.DrawStatusBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding ActiveDeckViewModel.DrawCount, Mode=OneWay}" Maximum="{Binding ActiveDeckViewModel.DrawGoal}" Height="4" Foreground="{Binding ActiveDeckViewModel.DrawStatusBrush}" Background="#1c1d24" BorderThickness="0" Margin="0,4,0,6"/>
                                </StackPanel>

                                <!-- Spot Removal Goal Tracker -->
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Removal" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActiveDeckViewModel.RemovalCount, StringFormat='{}{0}'}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.RemovalGoal, StringFormat='/ {0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,0"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.RemovalStatus, StringFormat=' ({0})'}" Foreground="{Binding ActiveDeckViewModel.RemovalStatusBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding ActiveDeckViewModel.RemovalCount, Mode=OneWay}" Maximum="{Binding ActiveDeckViewModel.RemovalGoal}" Height="4" Foreground="{Binding ActiveDeckViewModel.RemovalStatusBrush}" Background="#1c1d24" BorderThickness="0" Margin="0,4,0,6"/>
                                </StackPanel>

                                <!-- Board Wipes Goal Tracker -->
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Board Wipes" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActiveDeckViewModel.WipeCount, StringFormat='{}{0}'}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.WipeGoal, StringFormat='/ {0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,0"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.WipeStatus, StringFormat=' ({0})'}" Foreground="{Binding ActiveDeckViewModel.WipeStatusBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding ActiveDeckViewModel.WipeCount, Mode=OneWay}" Maximum="{Binding ActiveDeckViewModel.WipeGoal}" Height="4" Foreground="{Binding ActiveDeckViewModel.WipeStatusBrush}" Background="#1c1d24" BorderThickness="0" Margin="0,4,0,6"/>
                                </StackPanel>

                                <!-- Tutors Goal Tracker -->
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Tutors" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActiveDeckViewModel.TutorsCount, StringFormat='{}{0}'}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.TutorGoal, StringFormat='/ {0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,0"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.TutorStatus, StringFormat=' ({0})'}" Foreground="{Binding ActiveDeckViewModel.TutorStatusBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding ActiveDeckViewModel.TutorsCount, Mode=OneWay}" Maximum="{Binding ActiveDeckViewModel.TutorGoal}" Height="4" Foreground="{Binding ActiveDeckViewModel.TutorStatusBrush}" Background="#1c1d24" BorderThickness="0" Margin="0,4,0,6"/>
                                </StackPanel>

                                <!-- Win Conditions Goal Tracker -->
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Win Conditions" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActiveDeckViewModel.WinConditionsCount, StringFormat='{}{0}'}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.WinConditionGoal, StringFormat='/ {0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,0"/>
                                            <TextBlock Text="{Binding ActiveDeckViewModel.WinConditionStatus, StringFormat=' ({0})'}" Foreground="{Binding ActiveDeckViewModel.WinConditionStatusBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding ActiveDeckViewModel.WinConditionsCount, Mode=OneWay}" Maximum="{Binding ActiveDeckViewModel.WinConditionGoal}" Height="4" Foreground="{Binding ActiveDeckViewModel.WinConditionStatusBrush}" Background="#1c1d24" BorderThickness="0" Margin="0,4,0,6"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Content="Suggestions" HorizontalAlignment="Stretch" Padding="10" Background="#1c1d24" BorderBrush="#2c2e3c" Foreground="White" Click="OpenRecommendations_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            </Grid>
                    </TabItem>

                    <!-- TAB 2: LIST VIEW -->
                    <TabItem Header="List View">
                        <Grid Background="#0d0e12" Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Search & Filter -->
                                <RowDefinition Height="*"/>    <!-- ListView Grid -->
                            </Grid.RowDefinitions>

                             <Grid Grid.Row="0" Margin="0,0,0,16">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="*"/>
                                     <ColumnDefinition Width="Auto"/>
                                 </Grid.ColumnDefinitions>
                                 <ui:TextBox Grid.Column="0" Padding="10" Background="#121319" Foreground="White" BorderBrush="#2c2e3c" PlaceholderText="Search cards in deck..." Name="TxtDeckListFilter" TextChanged="TxtDeckListFilter_TextChanged"/>
                                 <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                     <StackPanel.Style>
                                         <Style TargetType="StackPanel">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding DeckListLayoutMode}" Value="Card Spoiler Grid">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </StackPanel.Style>
                                     <TextBlock Text="Zoom:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                     <Slider x:Name="CardZoomSlider" Minimum="0.5" Maximum="2.0" Value="1.0" Width="100" VerticalAlignment="Center"/>
                                     <TextBlock Text="{Binding ElementName=CardZoomSlider, Path=Value, StringFormat='{}{0:P0}'}" Foreground="White" FontSize="11" Width="36" TextAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                 </StackPanel>
                             </Grid>

                            <!-- Original DataGrid (Spreadsheet Grid) -->
                            <DataGrid Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single"
                                      HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                                      RowBackground="Transparent" AlternatingRowBackground="#08ffffff" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#1c1d24" RowHeaderWidth="0" Foreground="White" FontSize="12"
                                      Name="DeckListGrid" MouseDoubleClick="DeckListGrid_MouseDoubleClick"
                                      ItemsSource="{Binding ActiveDeckViewModel.Cards}">
                                <DataGrid.Style>
                                    <Style TargetType="DataGrid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DeckListLayoutMode}" Value="Spreadsheet Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Style>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" FontWeight="Bold"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeLine}" Width="*"/>
                                    <DataGridTextColumn Header="Cmc" Binding="{Binding Cmc}" Width="60" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                                    <DataGridTextColumn Header="Price" Binding="{Binding PriceUsd, StringFormat='{}{0:C}'}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Moxfield Card Spoiler Grid -->
                            <ListBox Grid.Row="1" ItemsSource="{Binding ActiveDeckViewModel.Cards}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible"
                                     Name="DeckSpoilerList" SelectionChanged="ListBox_SelectionChanged">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DeckListLayoutMode}" Value="Card Spoiler Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <EventSetter Event="MouseDoubleClick" Handler="DeckSpoilerItem_MouseDoubleClick"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6" Style="{StaticResource MtgCardBorder}" Width="122" Height="170" CornerRadius="8" Padding="1" ClipToBounds="True">
                                            <Border.LayoutTransform>
                                                <ScaleTransform ScaleX="{Binding ElementName=CardZoomSlider, Path=Value}" ScaleY="{Binding ElementName=CardZoomSlider, Path=Value}"/>
                                            </Border.LayoutTransform>
                                            <Grid>
                                                <!-- Card Image Presenter -->
                                                <views:CardImagePresenter Card="{Binding}" Width="120" Height="168"/>

                                                <!-- Live Quantity Badge top-left -->
                                                <Border Background="#e6caa13e" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="1" Margin="4" CornerRadius="4" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Quantity, StringFormat='{}x{0}'}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>

                                                <!-- Price Badge bottom-right -->
                                                <Border Background="#cc0d0e12" Margin="4" CornerRadius="4" Padding="4,1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding PriceUsd, StringFormat='{} ${0}'}" FontSize="9" FontWeight="Bold" Foreground="#4caf50"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <!-- TAB 3: ANALYTICS -->
                    <TabItem Header="Analytics" Selector.Selected="AnalyticsTab_Selected">
                        <views:AnalyticsView x:Name="DeckAnalyticsPanel"/>
                    </TabItem>
                </TabControl>

                <!-- Status Bar -->
                <StatusBar Grid.Row="2" Background="#0b0c10" BorderBrush="#20222a" BorderThickness="0,1,0,0" Padding="8,4">
                    <StatusBarItem>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#e6caa13e"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDbLoaded}" Value="True">
                                                <Setter Property="Fill" Value="Green"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </StatusBarItem>
                </StatusBar>
            </Grid>

            <!-- 2. PROXY PRINTER VIEW (ActiveView == 'ProxyPrinter') -->
            <Grid Visibility="{Binding ActiveView, Converter={StaticResource StringEqualToVisibilityConverter}, ConverterParameter=ProxyPrinter}">
                <Grid Background="{StaticResource ObsidianBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/> <!-- Left Sidebar for controls and card curation -->
                        <ColumnDefinition Width="*"/>   <!-- Right Workspace for simulated sheet preview -->
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDEBAR: CONTROLS & CURATION -->
                    <Border Grid.Column="0" Style="{StaticResource ObsidianGlassPanel}" Margin="20,16,0,16" Padding="14,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Print Button & Settings -->
                                <RowDefinition Height="Auto"/> <!-- Proxy Search Block -->
                                <RowDefinition Height="Auto"/> <!-- Curation Title & Utilities -->
                                <RowDefinition Height="*"/>    <!-- Scrollable Curation checklist -->
                            </Grid.RowDefinitions>

                            <!-- Settings Block -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,12" DataContext="{Binding ProxyPrinter}">
                                <Border Style="{StaticResource ObsidianGlassPanel}" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="PRINTER SETTINGS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,10"/>
                                        
                                        <!-- Paper Size -->
                                        <TextBlock Text="PAPER SIZE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding PaperSizes}" SelectedItem="{Binding PaperSize, Mode=TwoWay}" Margin="0,0,0,10" Height="38"/>

                                        <!-- Layout Mode -->
                                        <TextBlock Text="LAYOUT STYLE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding LayoutModes}" SelectedItem="{Binding LayoutMode, Mode=TwoWay}" Margin="0,0,0,10" Height="38"/>

                                        <!-- Guideline Style -->
                                        <TextBlock Text="GUIDELINE STYLE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding GuideStyles}" SelectedItem="{Binding GuideStyle, Mode=TwoWay}" Margin="0,0,0,10" Height="38"
                                                  ToolTip="Crop Marks: Draw crop crosshairs at corners.&#x0a;Dashed Margins: Draw fine dashed borders.&#x0a;Pure Black Borders: Draw solid black borders.&#x0a;None: No guidelines."/>

                                        <!-- Guide Color -->
                                        <TextBlock Text="GUIDE COLOR" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding GuideColors}" SelectedItem="{Binding GuideColor, Mode=TwoWay}" Margin="0,0,0,10" Height="38"
                                                  ToolTip="Choose a highly noticeable color (e.g. Red, Gold, White) that stands out clearly on your card printouts."/>

                                        <!-- Bleed Edge -->
                                         <CheckBox IsChecked="{Binding UseBleedEdge, Mode=TwoWay}" Content="Add Bleed Edge (1mm)" FontSize="11" Margin="0,4,0,4"
                                                   ToolTip="Slightly enlarges card images past the cut lines to guarantee no white borders when trimmed.">
                                             <CheckBox.Style>
                                                 <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding IsCricutMode}" Value="True">
                                                             <Setter Property="IsEnabled" Value="False"/>
                                                             <Setter Property="IsChecked" Value="True"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </CheckBox.Style>
                                         </CheckBox>

                                        <!-- Purify Borders -->
                                        <CheckBox IsChecked="{Binding PurifyBorders, Mode=TwoWay}" Content="Purify Borders" FontSize="11" Margin="0,4,0,4"
                                                  ToolTip="Cleans up card image edges to print crisp border lines"/>
                                    </StackPanel>
                                </Border>

                                <!-- Big Gold Print Button -->
                                <Button Click="PrintProxyDeck_Click" 
                                        Background="{StaticResource AccentGoldBrush}" 
                                        Foreground="Black" 
                                        FontWeight="Bold" 
                                        FontSize="14" 
                                        Padding="16" 
                                        Height="48"
                                        HorizontalAlignment="Stretch"
                                        BorderThickness="0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE2F6;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
                                        <TextBlock Text="PRINT PROXY DECK" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Direct Proxy Search Panel -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,12" DataContext="{Binding ProxyPrinter}">
                                <Border Style="{StaticResource ObsidianGlassPanel}" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="ADD CARD TO SHEET" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,8"/>
                                        <Grid>
                                            <TextBox x:Name="ProxySearchTextBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                                     Height="32" Padding="8,4" Background="#0b0c10" Foreground="White" BorderBrush="#2c2e3c"
                                                     GotFocus="ProxySearch_GotFocus" LostFocus="ProxySearch_LostFocus"/>
                                            <!-- Placeholder -->
                                            <TextBlock IsHitTestVisible="False" Text="Search card name to add..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="{StaticResource TextMutedBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementName=ProxySearchTextBox, Path=Text}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        
                                        <!-- Autocomplete Popup list -->
                                        <Popup x:Name="ProxySearchResultsPopup" IsOpen="{Binding IsSearchResultsOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=ProxySearchTextBox}" Placement="Bottom" StaysOpen="False" Width="324" Panel.ZIndex="5000">
                                            <Border Background="#17181f" BorderBrush="#2c2e3c" BorderThickness="1" CornerRadius="4" MaxHeight="250">
                                                <ListBox ItemsSource="{Binding SearchResults}" Background="Transparent" BorderThickness="0" SelectionChanged="ProxySearchResults_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="6,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding SetDisplay}" Foreground="{StaticResource AccentGoldBrush}" FontSize="9" Margin="8,0,0,0"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Curation checklist header -->
                            <Grid Grid.Row="2" Margin="0,0,0,8" DataContext="{Binding ProxyPrinter}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CURATE SHEET LIST" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Click="LoadActiveDeck_Click" Content="Load Deck" Padding="6,3" FontSize="9" Margin="0,0,4,0" Background="#1c1d26" BorderBrush="#2c2e3c"/>
                                    <Button Click="ClearSheet_Click" Content="Clear" Padding="6,3" FontSize="9" Margin="0,0,4,0" Background="#33ff0000" Foreground="Red" BorderBrush="Red"/>
                                    <Button Command="{Binding ToggleAllCommand}" Content="Toggle All" Padding="6,3" FontSize="9" Background="#1c1d26" BorderBrush="#2c2e3c"/>
                                </StackPanel>
                            </Grid>

                            <!-- Scrollable Curation checklist -->
                            <ListBox Grid.Row="3" ItemsSource="{Binding ProxyPrinter.PrintableCards}" Background="Transparent" BorderThickness="0" Margin="0,0,4,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource MtgCardBorder}" Padding="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/> <!-- Checkbox -->
                                                    <ColumnDefinition Width="*"/>    <!-- Name / Set -->
                                                    <ColumnDefinition Width="Auto"/> <!-- Up / Down Qty -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox -->
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                                <!-- Card Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Card.Name}" FontSize="12" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <!-- Set Code badge -->
                                                        <Border Background="#222430" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding Card.SetDisplay}" FontSize="8" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Card.PrimaryType}" FontSize="9" Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Numeric Up / Down -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <Button Content="-" Click="QtyDecrement_Click" Width="24" Height="24" Padding="0" VerticalAlignment="Center" BorderThickness="0" Background="#2c2e3c" Foreground="White"/>
                                                    <TextBox Text="{Binding PrintQuantity, UpdateSourceTrigger=PropertyChanged}" Width="28" Height="24" TextAlignment="Center" VerticalAlignment="Center" Background="#0b0c10" Foreground="White" BorderBrush="#2c2e3c" Margin="2,0"/>
                                                    <Button Content="+" Click="QtyIncrement_Click" Width="24" Height="24" Padding="0" VerticalAlignment="Center" BorderThickness="0" Background="#2c2e3c" Foreground="White"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- RIGHT WORKSPACE: simulated sheet preview & pagination -->
                    <Grid Grid.Column="0" Margin="20,16,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>    <!-- Paper canvas preview -->
                            <RowDefinition Height="Auto"/> <!-- Paginator control -->
                        </Grid.RowDefinitions>

                        <!-- Simulated Sheet View -->
                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#0b0c10">
                            <!-- We wrap SimulatedPaper inside a Viewbox to scale it down to screen size -->
                            <Viewbox Name="SimulatedPaperViewbox" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">

                                
                                <!-- Simulated Paper Sheet Border (using exact physical pixel dimensions in coordinate space) -->
                                <Border Name="SimulatedPaper" Background="White" CornerRadius="2"
                                        Width="{Binding ProxyPrinter.PageWidth}"
                                        Height="{Binding ProxyPrinter.PageHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="40" ShadowDepth="6" Color="Black" Opacity="0.5"/>
                                    </Border.Effect>

                                    <!-- Canvas of exact physical dimensions -->
                                    <Canvas x:Name="PrintPreviewCanvas" Width="{Binding ProxyPrinter.PageWidth}" Height="{Binding ProxyPrinter.PageHeight}">
                                        <!-- The 9 Interactive Card Slots positioned at physical offsets -->
                                        <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[0]}"
                                                          Canvas.Left="{Binding DataContext.ProxyPrinter.Slot0X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Canvas.Top="{Binding DataContext.ProxyPrinter.Slot0Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          ContentTemplate="{StaticResource CardSlotTemplate}"/>
                                        
                                        <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[1]}"
                                                          Canvas.Left="{Binding DataContext.ProxyPrinter.Slot1X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Canvas.Top="{Binding DataContext.ProxyPrinter.Slot0Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          ContentTemplate="{StaticResource CardSlotTemplate}"/>

                                         <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[2]}"
                                                           Canvas.Left="{Binding DataContext.ProxyPrinter.Slot2X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Canvas.Top="{Binding DataContext.ProxyPrinter.Slot0Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           ContentTemplate="{StaticResource CardSlotTemplate}">
                                             <ContentPresenter.Style>
                                                 <Style TargetType="ContentPresenter">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding DataContext.ProxyPrinter.LayoutMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Cricut (6 Cards)">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ContentPresenter.Style>
                                         </ContentPresenter>

                                        <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[3]}"
                                                          Canvas.Left="{Binding DataContext.ProxyPrinter.Slot0X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Canvas.Top="{Binding DataContext.ProxyPrinter.Slot1Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          ContentTemplate="{StaticResource CardSlotTemplate}"/>

                                        <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[4]}"
                                                          Canvas.Left="{Binding DataContext.ProxyPrinter.Slot1X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Canvas.Top="{Binding DataContext.ProxyPrinter.Slot1Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          ContentTemplate="{StaticResource CardSlotTemplate}"/>

                                         <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[5]}"
                                                           Canvas.Left="{Binding DataContext.ProxyPrinter.Slot2X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Canvas.Top="{Binding DataContext.ProxyPrinter.Slot1Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           ContentTemplate="{StaticResource CardSlotTemplate}">
                                             <ContentPresenter.Style>
                                                 <Style TargetType="ContentPresenter">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding DataContext.ProxyPrinter.LayoutMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Cricut (6 Cards)">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ContentPresenter.Style>
                                         </ContentPresenter>

                                        <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[6]}"
                                                          Canvas.Left="{Binding DataContext.ProxyPrinter.Slot0X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Canvas.Top="{Binding DataContext.ProxyPrinter.Slot2Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          ContentTemplate="{StaticResource CardSlotTemplate}"/>

                                        <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[7]}"
                                                          Canvas.Left="{Binding DataContext.ProxyPrinter.Slot1X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Canvas.Top="{Binding DataContext.ProxyPrinter.Slot2Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          ContentTemplate="{StaticResource CardSlotTemplate}"/>

                                         <ContentPresenter Content="{Binding ProxyPrinter.ActivePageCards[8]}"
                                                           Canvas.Left="{Binding DataContext.ProxyPrinter.Slot2X, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Canvas.Top="{Binding DataContext.ProxyPrinter.Slot2Y, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Width="{Binding DataContext.ProxyPrinter.SlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Height="{Binding DataContext.ProxyPrinter.SlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           ContentTemplate="{StaticResource CardSlotTemplate}">
                                             <ContentPresenter.Style>
                                                 <Style TargetType="ContentPresenter">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding DataContext.ProxyPrinter.LayoutMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Cricut (6 Cards)">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ContentPresenter.Style>
                                         </ContentPresenter>

                                        <!-- The Dynamic Crop Marks / Guidelines Canvas (Overlayed on top of cards) -->
                                        <Canvas Name="PreviewCropMarksCanvas" Width="{Binding ProxyPrinter.PageWidth}" Height="{Binding ProxyPrinter.PageHeight}" IsHitTestVisible="False"/>
                                    </Canvas>
                                </Border>
                            </Viewbox>
                        </ScrollViewer>


                        <!-- Paging Bar controls -->
                        <Border Grid.Row="1" Background="#121319" BorderBrush="#20222a" BorderThickness="1" CornerRadius="8" Padding="12,8" VerticalAlignment="Center" DataContext="{Binding ProxyPrinter}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Command="{Binding PrevPageCommand}" Background="#22232a" BorderBrush="#2c2e3c" Width="36" Height="36" Padding="0" ToolTip="Previous Page">
                                    <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"/>
                                </Button>

                                <TextBlock Grid.Column="1" Text="{Binding PageLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Button Grid.Column="2" Command="{Binding NextPageCommand}" Background="#22232a" BorderBrush="#2c2e3c" Width="36" Height="36" Padding="0" ToolTip="Next Page">
                                    <TextBlock Text="&#xE111;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- 3. DECK WIZARD VIEW (ActiveView == 'Wizard') -->
            <Grid Visibility="{Binding ActiveView, Converter={StaticResource StringEqualToVisibilityConverter}, ConverterParameter=Wizard}" Background="#0d0e12">
                <Border Style="{StaticResource ObsidianGlassPanel}" Margin="32" Padding="24">
                    <Grid DataContext="{Binding DeckWizard}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/> <!-- Left: Commander Card Preview -->
                            <ColumnDefinition Width="*"/>   <!-- Right: Setup Panels -->
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN: COMMANDER PREVIEW -->
                        <Border Grid.Column="0" BorderBrush="#20222a" BorderThickness="0,0,1,0" Padding="0,0,24,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Create a New Commander Deck" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
                                
                                <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True" Background="#0b0c10" VerticalAlignment="Center" Height="400">
                                    <Grid>
                                        <!-- Placeholder when no commander is selected -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding SelectedCommander, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                            <TextBlock Text="No Commander Selected" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- Active Commander card image -->
                                        <views:CardImagePresenter Card="{Binding SelectedCommander}" Visibility="{Binding SelectedCommander, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- RIGHT COLUMN: SETUP FORM -->
                        <Grid Grid.Column="1" Margin="24,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,12,0">
                                <StackPanel>
                                    <!-- 1. Commander Search -->
                                    <TextBlock Text="1. Commander" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,8"/>
                                    <ui:TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search commanders..." Padding="10,8" Margin="0,0,0,8"/>
                                    <ListBox Height="120" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedCommander, Mode=TwoWay}" Background="#121319" BorderBrush="#2c2e3c" Margin="0,0,0,24">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="{Binding TypeLine}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- 2. Choose a Theme -->
                                    <TextBlock Text="2. Choose a Theme" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,8"/>
                                    <UniformGrid Columns="4" Margin="0,0,0,24">
                                        <RadioButton Content="Counters" GroupName="WizardTheme" IsChecked="{Binding ThemeCounters}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                        <RadioButton Content="Tokens" GroupName="WizardTheme" IsChecked="{Binding ThemeTokens}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                        <RadioButton Content="Aristocrats" GroupName="WizardTheme" IsChecked="{Binding ThemeAristocrats}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                        <RadioButton Content="Spellslinger" GroupName="WizardTheme" IsChecked="{Binding ThemeSpellslinger}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                    </UniformGrid>

                                    <!-- 3. Choose Deck Power -->
                                    <TextBlock Text="3. Choose Deck Power" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,8"/>
                                    <UniformGrid Columns="4" Margin="0,0,0,24">
                                        <RadioButton Content="Casual" GroupName="WizardPower" IsChecked="{Binding PowerCasual}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                        <RadioButton Content="Focused" GroupName="WizardPower" IsChecked="{Binding PowerFocused}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                        <RadioButton Content="High Power" GroupName="WizardPower" IsChecked="{Binding PowerHigh}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                        <RadioButton Content="cEDH" GroupName="WizardPower" IsChecked="{Binding PowerCedh}" Style="{StaticResource ThemeSelectRadioButtonStyle}"/>
                                    </UniformGrid>

                                    <!-- 4. Choose Primary Strategy (Recommend 2) -->
                                    <TextBlock Text="4. Choose Primary Strategy (Recommend 2)" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,8"/>
                                    <UniformGrid Columns="6" Margin="0,0,0,16">
                                        <ToggleButton Content="Control" IsChecked="{Binding StrategyControl}" Style="{StaticResource StrategySelectToggleButtonStyle}"/>
                                        <ToggleButton Content="Combo" IsChecked="{Binding StrategyCombo}" Style="{StaticResource StrategySelectToggleButtonStyle}"/>
                                        <ToggleButton Content="Midrange" IsChecked="{Binding StrategyMidrange}" Style="{StaticResource StrategySelectToggleButtonStyle}"/>
                                        <ToggleButton Content="Aggro" IsChecked="{Binding StrategyAggro}" Style="{StaticResource StrategySelectToggleButtonStyle}"/>
                                        <ToggleButton Content="Value" IsChecked="{Binding StrategyValue}" Style="{StaticResource StrategySelectToggleButtonStyle}"/>
                                        <ToggleButton Content="Tribal" IsChecked="{Binding StrategyTribal}" Style="{StaticResource StrategySelectToggleButtonStyle}"/>
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Bottom Continue Button -->
                            <Border Grid.Row="1" BorderBrush="#20222a" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                <Button Content="Continue" Command="{Binding NextCommand}" HorizontalAlignment="Right" Width="140" Padding="12" Background="#5c2bb0" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            <!-- 4. SETTINGS VIEW (ActiveView == 'Settings') -->
            <Grid Visibility="{Binding ActiveView, Converter={StaticResource StringEqualToVisibilityConverter}, ConverterParameter=Settings}" Background="#0d0e12">
                <Border Style="{StaticResource ObsidianGlassPanel}" Margin="32" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Settings categories -->
                        <Border Grid.Column="0" BorderBrush="#20222a" BorderThickness="0,0,1,0" Padding="0,0,20,0">
                            <StackPanel>
                                <TextBlock Text="Settings" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,24"/>
                                <RadioButton Content="General" IsChecked="True" Style="{StaticResource SidebarNavigationRadioButtonStyle}" Tag="&#xE713;"/>
                            </StackPanel>
                        </Border>

                        <!-- Settings properties -->
                        <Grid Grid.Column="1" Margin="24,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,0,16,0" MaxWidth="500" HorizontalAlignment="Left">
                                    <TextBlock Text="General Settings" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>

                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="Default Format" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox SelectedItem="{Binding DefaultFormat}" Height="34">
                                            <ComboBoxItem Content="Commander (EDH)"/>
                                            <ComboBoxItem Content="Brawl"/>
                                            <ComboBoxItem Content="Standard"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="Default Deck Size" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox SelectedItem="{Binding DefaultDeckSize}" Height="34">
                                            <ComboBoxItem Content="100 Cards"/>
                                            <ComboBoxItem Content="60 Cards"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="Default Commander Tax" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding DefaultCommanderTax}" Height="34" VerticalContentAlignment="Center" Padding="8,0"/>
                                    </StackPanel>

                                    <CheckBox Content="Confirm card removals" IsChecked="{Binding ConfirmCardRemovals}" Margin="0,8"/>
                                    <CheckBox Content="Warn about off-color cards" IsChecked="{Binding WarnOffColorCards}" Margin="0,8"/>
                                    <CheckBox Content="Enable advanced validation warnings" IsChecked="{Binding EnableAdvancedWarnings}" Margin="0,8"/>
                                    <CheckBox Content="Show card roles in deck list" IsChecked="{Binding ShowCardRoles}" Margin="0,8"/>
                                    <CheckBox Content="Automatically sort deck" IsChecked="{Binding AutoSortDeck}" Margin="0,8"/>

                                    <StackPanel Margin="0,16,0,16">
                                        <TextBlock Text="Currency" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox SelectedItem="{Binding Currency}" Height="34">
                                            <ComboBoxItem Content="USD ($)"/>
                                            <ComboBoxItem Content="EUR (€)"/>
                                            <ComboBoxItem Content="TIX"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="Language" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox SelectedItem="{Binding Language}" Height="34">
                                            <ComboBoxItem Content="English"/>
                                            <ComboBoxItem Content="French"/>
                                            <ComboBoxItem Content="Spanish"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="Deck List Layout Mode" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ComboBox SelectedItem="{Binding DeckListLayoutMode}" ItemsSource="{Binding DeckListLayoutModes}" Height="34"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Save changes -->
                            <Button Grid.Row="1" Click="SaveDeck_Click" Content="Save Changes" Background="#5c2bb0" Foreground="White" BorderThickness="0" Padding="24,12" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="0,16,0,0"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
<!-- Database Download / Loading Screen Overlay -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="#f20d0e12" Visibility="{Binding ShowDownloadOverlay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border BorderBrush="{StaticResource ObsidianBorderBrush}" BorderThickness="1" CornerRadius="16" Background="#17181f" Width="500" Height="360" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title / Icon -->
                        <RowDefinition Height="*"/>    <!-- Info text / Status -->
                        <RowDefinition Height="Auto"/> <!-- Progress / Action button -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="&#xE815;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource AccentGoldBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="LOCAL CARD DATABASE SETUP" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Info text -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="{Binding DownloadDescription}"
                                   TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldBrush}"/>
                    </StackPanel>

                    <!-- Progress / Trigger Area -->
                    <Grid Grid.Row="2">
                        <Button Command="{Binding DownloadDatabaseCommand}"
                                Background="{StaticResource AccentGoldBrush}"
                                Foreground="Black"
                                FontSize="13"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Padding="24,12"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE118;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DownloadButtonText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- If downloading is in progress -->
                        <StackPanel HorizontalAlignment="Stretch">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress}" Height="8" Foreground="{StaticResource AccentGoldBrush}" Background="#2c2e3c" Margin="0,0,0,12" BorderThickness="0"/>
                            <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:F1}% Completed'}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 8. DECK HEALTH DASHBOARD VIEW (ActiveView == 'Analytics') -->
        <Grid Visibility="{Binding ActiveView, Converter={StaticResource StringEqualToVisibilityConverter}, ConverterParameter=Analytics}" Background="#0d0e12">
            <views:DeckHealthView DataContext="{Binding ActiveDeckViewModel}"/>
        </Grid>

        <!-- Import / Export Popups/Dialog overlays -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Name="DialogOverlay" Visibility="Collapsed" Background="#b3000000" Panel.ZIndex="1000">
            <Border Style="{StaticResource ObsidianGlassPanel}" Width="500" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Text Input/Output -->
                        <RowDefinition Height="Auto"/> <!-- Actions -->
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="DialogTitle" Text="Import Deck from Text" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <TextBox x:Name="DialogTextBox" Grid.Row="1" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#0b0c10" Foreground="White" BorderBrush="#2c2e3c" Padding="12" Margin="0,0,0,16" FontFamily="Consolas"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="DialogCancel_Click" Margin="0,0,8,0" Padding="12,6"/>
                        <Button x:Name="DialogActionBtn" Content="Import" Click="DialogAction_Click" Padding="16,6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
